# HTTP port the app listens on
PORT=3000

# Redis connection URL
# - inside docker compose: redis://redis:6379  (service hostname)
# - running locally outside docker: redis://localhost:6379
REDIS_URL=redis://redis:6379

# Redis sorted-set key holding all device geo positions
GEO_KEY=device_locations

# Default search radius (metres) for GET /nearby when ?radius is omitted
DEFAULT_RADIUS_METERS=1000
